{
  "root": true,
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:prettier/recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "prettier/prettier": "error",
    "no-unused-vars": "warn",
    "no-console": "off"
  },
  "overrides": [
    {
      "files": [
        "playwright/**/*.spec.{js,ts}",
        "playwright/**/*.test.{js,ts}"
      ],
      "extends": [
        "plugin:playwright/recommended"
      ],
      "rules": {
        "playwright/no-skipped-test": "warn"
      }
    }
  ]
}